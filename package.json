{
  "name": "leakguard",
  "version": "0.1.0",
  "description": "AI-powered static analyzer for resource leaks and path-based logic bugs.",
  "type": "module",
  "bin": {
    "leakguard": "dist/index.js"
  },
  "files": [
    "dist",
    "prompts",
    "schemas",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "ajv": "^8.17.1",
    "chalk": "^5.4.1",
    "cli-progress": "^3.12.0",
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0",
    "glob": "^11.0.1",
    "openai": "^5.8.2",
    "ora": "^8.2.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-c": "^0.21.4",
    "tree-sitter-cpp": "^0.21.0",
    "tree-sitter-go": "^0.21.2",
    "tree-sitter-java": "^0.21.0",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-rust": "^0.21.0",
    "tree-sitter-typescript": "^0.21.2",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "eslint": "^9.25.1",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
