{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["resources", "summary"],
  "properties": {
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "acquire", "expected_releases", "actual_releases", "execution_paths"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["transaction", "file_handle", "lock", "connection", "memory", "context", "channel", "custom"]
          },
          "acquire": {
            "type": "object",
            "required": ["expression", "line", "variable"],
            "properties": {
              "expression": { "type": "string" },
              "line": { "type": "number" },
              "variable": { "type": "string" }
            }
          },
          "expected_releases": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["expression", "type", "description"],
              "properties": {
                "expression": { "type": "string" },
                "type": { "type": "string", "enum": ["normal", "error", "cleanup"] },
                "description": { "type": "string" }
              }
            }
          },
          "actual_releases": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["expression", "line", "on_path", "covers_error_paths"],
              "properties": {
                "expression": { "type": "string" },
                "line": { "type": "number" },
                "on_path": { "type": "string" },
                "covers_error_paths": { "type": "boolean" }
              }
            }
          },
          "execution_paths": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "description", "lines", "resource_released", "release_mechanism", "notes"],
              "properties": {
                "id": { "type": "string" },
                "description": { "type": "string" },
                "lines": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 2,
                  "maxItems": 2
                },
                "resource_released": { "type": "boolean" },
                "release_mechanism": {
                  "type": "string",
                  "enum": ["direct_call", "defer", "finally", "with_statement", "RAII", "none"]
                },
                "notes": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_resources", "total_paths", "paths_with_missing_release", "risk_level"],
      "properties": {
        "total_resources": { "type": "number" },
        "total_paths": { "type": "number" },
        "paths_with_missing_release": { "type": "number" },
        "risk_level": {
          "type": "string",
          "enum": ["none", "low", "medium", "high", "critical"]
        }
      }
    }
  }
}
